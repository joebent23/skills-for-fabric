{
  "dataset": "eval_sales_model",
  "source_eval": "PBA-01 / PBA-02 / PBA-03",
  "model": {
    "displayName": "eval_sales_model",
    "tables": [
      {
        "name": "Sales",
        "columns": [
          {"name": "SalesId", "dataType": "int64", "isKey": true},
          {"name": "ProductName", "dataType": "string"},
          {"name": "Quantity", "dataType": "int64"},
          {"name": "UnitPrice", "dataType": "decimal"},
          {"name": "TotalAmount", "dataType": "decimal"},
          {"name": "SaleDate", "dataType": "dateTime"},
          {"name": "Region", "dataType": "string"}
        ],
        "measures": [
          {
            "name": "Total Revenue",
            "expression": "SUMX(Sales, Sales[Quantity] * Sales[UnitPrice])",
            "formatString": "$#,##0.00"
          },
          {
            "name": "Average Price",
            "expression": "AVERAGE(Sales[UnitPrice])",
            "formatString": "$#,##0.00"
          }
        ],
        "partition_mode": "import"
      },
      {
        "name": "Date",
        "columns": [
          {"name": "Date", "dataType": "dateTime", "isKey": true},
          {"name": "Year", "dataType": "int64"},
          {"name": "Quarter", "dataType": "string"},
          {"name": "Month", "dataType": "string"},
          {"name": "MonthNumber", "dataType": "int64"}
        ],
        "measures": [],
        "partition_mode": "import"
      }
    ],
    "relationships": [
      {
        "fromTable": "Sales",
        "fromColumn": "SaleDate",
        "toTable": "Date",
        "toColumn": "Date",
        "cardinality": "manyToOne",
        "crossFilterDirection": "single"
      }
    ],
    "hierarchies": [
      {
        "table": "Date",
        "name": "Calendar",
        "levels": [
          {"name": "Year", "column": "Year", "ordinal": 0},
          {"name": "Quarter", "column": "Quarter", "ordinal": 1},
          {"name": "Month", "column": "Month", "ordinal": 2}
        ]
      }
    ],
    "calculationGroups": [
      {
        "table": "Time Intelligence",
        "column": "Time Calculation",
        "items": [
          {"name": "Current", "expression": "SELECTEDMEASURE()"},
          {"name": "YTD", "expression": "CALCULATE(SELECTEDMEASURE(), DATESYTD('Date'[Date]))"},
          {"name": "PY", "expression": "CALCULATE(SELECTEDMEASURE(), SAMEPERIODLASTYEAR('Date'[Date]))"},
          {"name": "PY YTD", "expression": "CALCULATE(SELECTEDMEASURE(), DATESYTD(SAMEPERIODLASTYEAR('Date'[Date])))"}
        ]
      }
    ],
    "cultures": [
      {
        "name": "fr-FR",
        "translations": [
          {"object": "Sales", "type": "table", "translatedCaption": "Ventes"},
          {"object": "Date", "type": "table", "translatedCaption": "Calendrier"},
          {"object": "Total Revenue", "type": "measure", "translatedCaption": "Revenu Total"},
          {"object": "Region", "type": "column", "translatedCaption": "Région"}
        ]
      }
    ],
    "roles": [
      {
        "name": "RegionalManager",
        "modelPermission": "read",
        "tablePermissions": [
          {
            "table": "Sales",
            "filterExpression": "[Region] = \"East\""
          }
        ]
      }
    ]
  },
  "definition_parts": [
    "definition.pbism",
    "definition/database.tmdl",
    "definition/model.tmdl",
    "definition/tables/Sales.tmdl",
    "definition/tables/Date.tmdl",
    "definition/tables/Time Intelligence.tmdl",
    "definition/roles/RegionalManager.tmdl",
    "definition/cultures/fr-FR.tmdl"
  ]
}
